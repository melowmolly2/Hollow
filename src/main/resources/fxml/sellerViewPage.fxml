<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="560.0"
      prefWidth="760.0"
      spacing="14.0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.auction.SellerViewPage">
   <padding>
      <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <Button mnemonicParsing="false"
                    onAction="#back"
                    text="Back"
                    style="-fx-background-radius: 5; -fx-padding: 7 13;" />
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="titleLabel"
                         text="Auction title"
                         wrapText="true"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                  <Label fx:id="statusLabel"
                         text="Status: loading..."
                         style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
               </children>
            </VBox>
            <Button fx:id="editAuctionButton"
                    mnemonicParsing="false"
                    onAction="#editAuction"
                    text="Edit Auction"
                    style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 5; -fx-background-radius: 5; -fx-text-fill: #374151; -fx-padding: 8 13;" />
            <Button fx:id="endAuctionButton"
                    mnemonicParsing="false"
                    onAction="#endAuction"
                    text="End Auction"
                    style="-fx-background-color: #991b1b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 13;" />
         </children>
      </HBox>

      <HBox spacing="14.0">
         <children>
            <VBox spacing="8.0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;">
               <children>
                  <Label text="Current price"
                         style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" />
                  <Label fx:id="currentPriceLabel"
                         text="Current price: loading..."
                         wrapText="true"
                         style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1f6f43;" />
                  <Label fx:id="highestBidderLabel"
                         text="Highest bidder: loading..."
                         wrapText="true"
                         style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" />
               </children>
            </VBox>

            <VBox spacing="8.0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;">
               <children>
                  <Label text="Auction rules"
                         style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" />
                  <Label fx:id="startingPriceLabel" text="Starting price: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
                  <Label fx:id="bidIncrementLabel" text="Bid increment: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
                  <Label fx:id="buyNowPriceLabel" text="Buy now price: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
               </children>
            </VBox>
         </children>
      </HBox>

      <GridPane hgap="14.0" vgap="14.0" VBox.vgrow="ALWAYS">
         <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="330.0" percentWidth="46.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="380.0" percentWidth="54.0" />
         </columnConstraints>
         <children>
            <VBox spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;"
                  GridPane.columnIndex="0">
               <children>
                  <Label text="Item information"
                         style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                  <Separator />
                  <Label fx:id="descriptionLabel"
                         text="Description"
                         wrapText="true"
                         style="-fx-font-size: 13px; -fx-text-fill: #4b5563;" />
                  <Region VBox.vgrow="ALWAYS" />
                  <Separator />
                  <Label fx:id="startTimeLabel" text="Start time: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
                  <Label fx:id="endTimeLabel" text="End time: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
                  <Label fx:id="maxEndTimeLabel" text="Max end time: loading..." wrapText="true" style="-fx-text-fill: #4b5563;" />
                  <Label fx:id="actionHelpLabel"
                         text="Edit is unavailable because the backend has no update endpoint."
                         wrapText="true"
                         style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" />
               </children>
            </VBox>

            <VBox spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;"
                  GridPane.columnIndex="1">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <children>
                        <Label text="Bid history"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                        <Label fx:id="bidHistorySummaryLabel"
                               text="Bid percentage over starting price"
                               style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                     </children>
                  </HBox>
                  <LineChart fx:id="bidHistoryChart"
                             animated="false"
                             legendVisible="false"
                             prefHeight="330.0"
                             VBox.vgrow="ALWAYS">
                    <xAxis>
                      <CategoryAxis fx:id="bidTimeAxis" side="BOTTOM" label="Bid #" />
                    </xAxis>
                    <yAxis>
                      <NumberAxis fx:id="bidPriceAxis" side="LEFT" label="Percent of starting price" />
                    </yAxis>
                  </LineChart>
               </children>
            </VBox>
         </children>
      </GridPane>
   </children>
</VBox>
