<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0"
            prefWidth="760.0"
            style="-fx-background-color: transparent;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.auction.DashboardTab">
   <top>
      <VBox spacing="16.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <VBox spacing="4.0">
                     <children>
                        <Label text="Dashboard" styleClass="page-title" />
                        <Label text="Auction activity overview" styleClass="muted-label" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false"
                          onAction="#refresh"
                          styleClass="primary-button"
                          text="Refresh" />
               </children>
            </HBox>

            <HBox spacing="14.0">
               <children>
                  <VBox prefWidth="230.0" spacing="8.0" styleClass="metric-card">
                     <children>
                        <Label text="Ongoing Auctions" styleClass="metric-title" />
                        <Label fx:id="ongoingAuctionsLabel" text="-" styleClass="metric-value" />
                        <Label text="Live auctions on the marketplace" styleClass="metric-caption" />
                     </children>
                  </VBox>

                  <VBox prefWidth="230.0" spacing="8.0" styleClass="metric-card">
                     <children>
                        <Label text="Your Active Auctions" styleClass="metric-title" />
                        <Label fx:id="yourActiveAuctionsLabel" text="-" styleClass="metric-value" />
                        <Label text="Your listed auctions still open" styleClass="metric-caption" />
                     </children>
                  </VBox>

                  <VBox prefWidth="230.0" spacing="8.0" styleClass="metric-card">
                     <children>
                        <Label text="Your Wins" styleClass="metric-title" />
                        <Label fx:id="yourWinsLabel" text="-" styleClass="metric-value" />
                        <Label text="Auctions you have won" styleClass="metric-caption" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  style="-fx-background-color: transparent; -fx-padding: 18 0 0 0;"
                  BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="12.0" styleClass="dashboard-panel">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label text="Winning History" styleClass="section-title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="statusLabel" text="Loading dashboard..." styleClass="muted-label" />
                     </children>
                  </HBox>
                  <TableView fx:id="winningHistoryTable"
                             prefHeight="250.0"
                             styleClass="history-table">
                     <columns>
                        <TableColumn fx:id="winTitleColumn" prefWidth="310.0" text="Auction" />
                        <TableColumn fx:id="winBidColumn" prefWidth="150.0" text="Winning Bid" />
                        <TableColumn fx:id="winTimeColumn" prefWidth="210.0" text="Bid Time" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
