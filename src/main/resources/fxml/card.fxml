<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="170.0"
      prefWidth="230.0"
      spacing="8.0"
      style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 12;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.auction.Card">
   <children>
      <Label fx:id="itemLabel" text="Item:"
             maxHeight="42.0"
             wrapText="true"
             style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
      <Label fx:id="infoLabel" text="Info:"
             maxHeight="38.0"
             wrapText="true"
             style="-fx-text-fill: #4b5563;" />
      <Separator />
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <children>
            <Label fx:id="priceLabel" text="Price:"
                   HBox.hgrow="ALWAYS"
                   style="-fx-text-fill: #1f6f43; -fx-font-weight: bold;" />
            <Label fx:id="timeLabel" text="Time:"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" />
         </children>
      </HBox>
      <Region VBox.vgrow="ALWAYS" />
      <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#seeDetails" prefHeight="32.0" text="See details"
              style="-fx-background-color: #20242c; -fx-text-fill: white; -fx-background-radius: 5;" />
   </children>
</VBox>
