<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="560.0" prefWidth="760.0"
      spacing="18.0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.account.AccountPage">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <Button mnemonicParsing="false" onAction="#back" text="Back"
                    style="-fx-background-radius: 5; -fx-padding: 7 13;" />
            <Label text="Account"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
         </children>
      </HBox>
      <VBox maxWidth="420.0"
            spacing="12.0"
            style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 20;">
         <children>
            <Label text="Wallet"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
            <Label fx:id="balanceLabel" text="Your balance: 0.0"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f6f43;" />
            <Label text="Add to your balance"
                   style="-fx-text-fill: #4b5563;" />
            <HBox spacing="10.0">
               <children>
                  <TextField fx:id="addField" promptText="Amount"
                             prefWidth="210.0"
                             style="-fx-background-radius: 5; -fx-padding: 9 11;" />
                  <Button mnemonicParsing="false" onAction="#add" text="Add"
                          style="-fx-background-color: #1f6f43; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 9 16;" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox maxWidth="420.0"
            spacing="10.0"
            style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 20;">
         <children>
            <Label text="Account settings"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
            <Label text="Logout will be added later."
                   style="-fx-text-fill: #6b7280;" />
         </children>
      </VBox>
   </children>
</VBox>
