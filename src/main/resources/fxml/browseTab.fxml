<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="760.0"
            style="-fx-background-color: transparent;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.auction.BrowseTab">
   <top>
      <VBox spacing="12.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Browse Auctions"
                    style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
         </children>
      </VBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true"
                  hbarPolicy="NEVER"
                  style="-fx-background-color: transparent; -fx-padding: 18 0 0 0;"
                  BorderPane.alignment="CENTER">
         <content>
            <FlowPane fx:id="cardContainer"
                      hgap="14.0"
                      prefWrapLength="720.0"
                      style="-fx-background-color: transparent;"
                      vgap="14.0" />
         </content>
      </ScrollPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT"
            spacing="10.0"
            style="-fx-padding: 14 0 0 0;"
            BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="pageLabel" text="Page 1"
                   style="-fx-text-fill: #4b5563;" />
            <Button fx:id="prevButton" mnemonicParsing="false" onAction="#prev" text="Prev"
                    style="-fx-background-radius: 5; -fx-padding: 7 13;" />
            <Button fx:id="nextButton" mnemonicParsing="false" onAction="#next" text="Next"
                    style="-fx-background-color: #1f6f43; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 7 13;" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
