<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="560.0"
      prefWidth="760.0"
      spacing="14.0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.auction.BidderViewPage">
   <padding>
      <Insets bottom="2.0" left="2.0" right="2.0" top="2.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <Button mnemonicParsing="false"
                    onAction="#back"
                    text="Back"
                    style="-fx-background-radius: 5; -fx-padding: 7 13;" />
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="titleLabel"
                         text="A title"
                         wrapText="true"
                         style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                  <Label text="Live auction detail"
                         style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
               </children>
            </VBox>
         </children>
      </HBox>

      <VBox spacing="14.0" VBox.vgrow="ALWAYS">
         <children>
            <HBox spacing="14.0">
               <children>
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;">
                     <children>
                        <Label text="Current price"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" />
                        <Label fx:id="currentPriceLabel"
                               text="Current price"
                               wrapText="true"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1f6f43;" />
                        <Label fx:id="highestBidderLabel"
                               text="Highest bidder"
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;">
                     <children>
                        <Label text="Place bid"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                        <Label fx:id="minimumBidLabel"
                               text="Your new bid:"
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                        <HBox spacing="10.0">
                           <children>
                              <TextField fx:id="bidAmountField"
                                         promptText="Bid amount"
                                         HBox.hgrow="ALWAYS"
                                         style="-fx-background-radius: 5; -fx-padding: 10 11;" />
                              <Button fx:id="confirmBidButton"
                                      mnemonicParsing="false"
                                      onAction="#confirmBid"
                                      text="Confirm"
                                      style="-fx-background-color: #1f6f43; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 14;" />
                           </children>
                        </HBox>
                        <Label fx:id="lastBidLabel"
                               text="Your last bid: None"
                               style="-fx-font-size: 12px; -fx-text-fill: #9ca3af;" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox spacing="10.0"
                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;">
               <children>
                  <Label text="Auction information"
                         style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                  <GridPane hgap="16.0" vgap="8.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                     </columnConstraints>
                     <children>
                        <Label fx:id="startingPriceLabel" text="Starting price" wrapText="true" style="-fx-text-fill: #4b5563;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Label fx:id="bidIncrementLabel" text="Bid increment" wrapText="true" style="-fx-text-fill: #4b5563;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label fx:id="startTimeLabel" text="Start time" wrapText="true" style="-fx-text-fill: #4b5563;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <Label fx:id="endTimeLabel" text="End time" wrapText="true" style="-fx-text-fill: #4b5563;" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                     </children>
                  </GridPane>
               </children>
            </VBox>

            <GridPane hgap="14.0" vgap="14.0" VBox.vgrow="ALWAYS">
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="350.0" percentWidth="62.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="220.0" percentWidth="38.0" />
               </columnConstraints>
               <children>
                  <VBox spacing="10.0"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="0">
                     <children>
                        <Label text="Description"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                        <Separator />
                        <Label fx:id="descriptionLabel"
                               text="Description"
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #4b5563;" />
                        <Region VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>

                  <VBox spacing="9.0"
                        style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-padding: 16;"
                        GridPane.columnIndex="1"
                        GridPane.rowIndex="0">
                     <children>
                        <Label text="Auto-bidding"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
                        <Label fx:id="autoBidStatusLabel"
                               text="Autobid: disabled"
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6b7280;" />
                        <TextField fx:id="maxBidLimitField"
                                   promptText="Max bid limit"
                                   style="-fx-background-radius: 5; -fx-padding: 8 10;" />
                        <Button fx:id="autoBidButton"
                                mnemonicParsing="false"
                                onAction="#submitAutoBid"
                                text="Set auto-bid"
                                style="-fx-background-color: #1f6f43; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 9 14;" />
                        <Region VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </children>
            </GridPane>
         </children>
      </VBox>
   </children>
</VBox>
